# kill existing window that covers everything (KDE Plasma)
  for_window [title="Desktop — Plasma"] kill; floating enable; border none
  #for_window [title="Desktop — Plasma"] move container to workspace $ws1; border none

  # remove borders for plasmashell widgets
  for_window [class="plasmashell"] border none

  #smart_gaps on
  smart_borders on

# Floating exceptions
  for_window [class="gnome-calendar"] floating enable
  for_window [class="krunner"] floating enable; move position center

# Automove window to workspace
  for_window [class="Spotify"] move container to workspace $ws9
  for_window [class="discord"] move container to workspace $ws10

# autostart
  #exec_always --no-startup-id sh ~/.config/polybar/launch.sh
  exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
  exec_always --no-startup-id wal -r
  exec --no-startup-id libinput-gestures-setup start

# Scratchpads
  for_window [class="whatsdesk"] move scratchpad; 
  bindsym $mod+minus [class="whatsdesk"] scratchpad show; move position center

# notifications position
  for_window [window_type="notification"] move position 1550 50; 
  
