#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
set -e
# Skip if core tools are already present.
command -v nvim >/dev/null 2>&1 && command -v starship >/dev/null 2>&1 && exit 0
brew install neovim starship zellij fzf ripgrep
brew install --cask wezterm ghostty
{{- else if eq .chezmoi.os "linux" -}}
set -e
command -v nvim >/dev/null 2>&1 && command -v starship >/dev/null 2>&1 && exit 0
if command -v pacman >/dev/null 2>&1; then
  sudo pacman -S --needed --noconfirm neovim starship zellij fzf ripgrep ttf-jetbrains-mono-nerd
  echo "NOTE: wezterm & ghostty are in the AUR (paru/yay)"
elif command -v apt >/dev/null 2>&1; then
  sudo apt update && sudo apt install -y neovim fzf ripgrep curl
  echo "NOTE: install starship/zellij/wezterm/ghostty via their official installers"
fi
{{- end }}
