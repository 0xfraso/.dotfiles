{
  "name": "pi-ssh-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pi SSH extension for routing built-in file and shell tools to a remote host",
  "scripts": {
    "check": "tsc --noEmit -p ./tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "^0.65.0",
    "@types/node": "^24.5.0",
    "typescript": "^5.9.2"
  }
}
