alias nv="nvim"
alias lg="lazygit"
alias dots="cd ~/.dotfiles/"
alias py="python3"
alias clip='xclip -selection clipboard'
alias hh="npx hardhat"

alias b="bat --color=always --theme=gruvbox-dark"

alias tt='tt -words ~/tt/words/it -theme=gruvbox-dark -showwpm'

alias anime='mpv $(find . -type f | sort | fzf)'
