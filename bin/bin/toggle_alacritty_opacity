#!/usr/bin/env bash

[[ ! -f ~/.config/alacritty/alacritty.yml ]] \
    && notify-send "alacritty.yml does not exist" \
    && exit 0

opacity=$(awk '$1 == "opacity:" {print $2; exit}'\
    ~/.config/alacritty/alacritty.yml)

case $opacity in
    1)
        toggle_opacity=0.92
        ;;
    *)
        toggle_opacity=1
        ;;
esac

sed -i -- "s/opacity: $opacity/opacity: $toggle_opacity/"   \
        ~/.config/alacritty/alacritty.yml
